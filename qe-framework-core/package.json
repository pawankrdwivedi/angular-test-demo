{
  "name": "qe-framework-core",
  "version": "1.0.0",
  "description": "Enterprise-grade scalable BDD/Playwright test automation core framework",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild index.js --bundle --platform=node --format=esm --outfile=dist/index.js --external:axios --external:winston --external:ajv --external:ajv-formats --external:playwright --external:@playwright/test --external:mysql2 --external:oracledb --external:pg --external:tedious --external:dotenv --external:xlsx --external:csv-parse --external:js-yaml --external:@cucumber/cucumber --external:@faker-js/faker --minify",
    "pack": "npm run build && npm pack"
  },
  "peerDependencies": {
    "@cucumber/cucumber": "^10.6.0",
    "@faker-js/faker": "^8.4.1",
    "ajv": "^8.16.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.7.2",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "mysql2": "^3.10.0",
    "oracledb": "^6.5.0",
    "pg": "^8.12.0",
    "playwright": "^1.44.1",
    "tedious": "^18.2.0",
    "winston": "^3.13.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "esbuild": "^0.21.3"
  }
}
